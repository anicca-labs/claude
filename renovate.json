{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["every weekend"],
  "timezone": "America/Buenos_Aires",
  "labels": ["dependencies"],
  "assignees": ["ksairi"],
  "packageRules": [
    {
      "description": "TypeScript + types — safe to automerge patch/minor",
      "groupName": "TypeScript & types",
      "matchPackageNames": ["typescript", "@types/*"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Patch-only updates for everything else — automerge safely",
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["on the first day of the month"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
